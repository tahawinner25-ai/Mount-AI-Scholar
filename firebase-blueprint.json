{
  "entities": {
    "LearningItem": {
      "title": "Learning Item",
      "description": "A piece of learning content generated by the AI (summary, quiz, mindmap).",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who requested the generation"
        },
        "mode": {
          "type": "string",
          "enum": ["summary", "quiz", "mindmap", "presentation"]
        },
        "language": {
          "type": "string"
        },
        "originalText": {
          "type": "string"
        },
        "generatedContent": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer",
          "description": "Timestamp in milliseconds"
        }
      },
      "required": ["userId", "mode", "language", "originalText", "generatedContent", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and stats.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin"]
        },
        "learningScore": {
          "type": "integer"
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": ["userId", "role", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile data."
    },
    "learning_items/{itemId}": {
      "schema": {
        "$ref": "#/entities/LearningItem"
      },
      "description": "Generated study materials."
    }
  }
}
