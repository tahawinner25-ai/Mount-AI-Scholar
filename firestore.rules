rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    // --- ENTITY VALIDATION BLUEPRINTS ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'role', 'createdAt']) &&
        data.keys().size() >= 3 &&
        data.userId == request.auth.uid &&
        data.role is string && data.role in ['student', 'admin'] &&
        data.createdAt is timestamp;
    }

    function isValidLearningItem(data) {
      return data.keys().hasAll(['userId', 'mode', 'language', 'originalText', 'generatedContent', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.mode is string && data.mode in ['summary', 'quiz', 'mindmap', 'presentation'] &&
        data.language is string && data.language.size() <= 50 &&
        data.originalText is string && data.originalText.size() <= 100000 &&
        data.generatedContent is string && data.generatedContent.size() <= 100000 &&
        data.createdAt is timestamp;
    }

    // --- COLLECTIONS ---

    // 1. users
    match /users/{userId} {
      allow get: if isValidId(userId) && isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      allow create: if isValidId(userId) && 
                       isSignedIn() &&
                       request.auth.uid == userId && 
                       isValidUserProfile(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().role == 'student'; // Force student role on creation
                       
      allow update: if isValidId(userId) && 
                       isSignedIn() &&
                       (request.auth.uid == userId || isAdmin()) &&
                       isValidUserProfile(incoming()) &&
                       incoming().userId == existing().userId && 
                       incoming().createdAt == existing().createdAt &&
                       (
                         // Student update their score
                         (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['learningScore'])) ||
                         // Admins can update roles
                         (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'learningScore']))
                       );
      
      allow delete: if false; // No deletion currently
    }

    // 2. learning_items
    match /learning_items/{itemId} {
      allow get: if isValidId(itemId) && isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isValidId(itemId) && 
                       isSignedIn() && 
                       isValidLearningItem(incoming()) &&
                       incoming().createdAt == request.time &&
                       exists(/databases/$(database)/documents/users/$(request.auth.uid));
                       
      allow update: if false; // Learning items are immutable
      allow delete: if isValidId(itemId) && isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
