{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile holding basic roles and creation timestamps.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "role", "createdAt"]
    },
    "LearningItem": {
      "title": "LearningItem",
      "description": "An item generated through AI (summary, quiz, mindmap).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string" },
        "language": { "type": "string" },
        "originalText": { "type": "string" },
        "generatedContent": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "mode", "language", "originalText", "generatedContent", "createdAt"]
    },
    "SyncLedgerEntry": {
      "title": "SyncLedgerEntry",
      "description": "Cryptographic offline ledger synchronization record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "seqId": { "type": "string" },
        "mutationType": { "type": "string" },
        "payloadJson": { "type": "string" },
        "checksum": { "type": "string" },
        "timestamp": { "type": "string" },
        "syncStatus": { "type": "string" }
      },
      "required": ["userId", "seqId", "mutationType", "payloadJson", "checksum", "timestamp", "syncStatus"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile"
    },
    "/learning_items/{itemId}": {
      "schema": { "$ref": "#/entities/LearningItem" },
      "description": "Records of AI generations requests and responses"
    },
    "/sync_ledger/{txId}": {
      "schema": { "$ref": "#/entities/SyncLedgerEntry" },
      "description": "Offline-first transactional ledger verification log"
    }
  }
}
