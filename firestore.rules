rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Helpers
    function isValidUser(data, uid) {
      return data.keys().hasAll(['userId', 'role', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.userId == uid &&
             data.role is string && data.role.size() <= 20 &&
             data.createdAt == request.time;
    }
    
    function isValidLearningItem(data) {
      return data.keys().hasAll(['userId', 'mode', 'language', 'originalText', 'generatedContent', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.mode is string && data.mode.size() <= 20 &&
             data.language is string && data.language.size() <= 50 &&
             data.originalText is string && data.originalText.size() <= 400000 &&
             data.generatedContent is string && data.generatedContent.size() <= 400000 &&
             data.createdAt == request.time;
    }

    function isValidLedgerEntry(data) {
      return data.keys().hasAll(['userId', 'seqId', 'mutationType', 'payloadJson', 'checksum', 'timestamp', 'syncStatus', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.seqId is string && data.seqId.size() <= 64 &&
             data.mutationType is string && data.mutationType.size() <= 100 &&
             data.payloadJson is string && data.payloadJson.size() <= 40000 &&
             data.checksum is string && data.checksum.size() <= 256 &&
             data.timestamp is string && data.timestamp.size() <= 128 &&
             data.syncStatus is string && data.syncStatus.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidSovereignShortMem(data) {
      return data.keys().hasAll(['userId', 'learningStyle', 'level', 'customDirectives', 'lastSessionInsights', 'preferredLanguage', 'syncedAt', 'createdAt']) && 
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.learningStyle is string && data.learningStyle.size() <= 200 &&
             data.level is string && data.level.size() <= 100 &&
             data.customDirectives is string && data.customDirectives.size() <= 15000 &&
             data.lastSessionInsights is string && data.lastSessionInsights.size() <= 15000 &&
             data.preferredLanguage is string && data.preferredLanguage.size() <= 100 &&
             data.syncedAt is string && data.syncedAt.size() <= 200 &&
             data.createdAt == request.time;
    }

    // users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow list: if false;

      allow create: if isVerified() && 
                    isValidId(userId) && 
                    userId == request.auth.uid && 
                    isValidUser(incoming(), userId);

      allow update: if false;
      allow delete: if false;
    }

    // sovereign_short_mem Collection
    match /sovereign_short_mem/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow list: if false;

      allow create: if isVerified() &&
                    isValidId(userId) &&
                    userId == request.auth.uid &&
                    isValidSovereignShortMem(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid));

      allow update: if isVerified() &&
                    isValidId(userId) &&
                    userId == request.auth.uid &&
                    isValidSovereignShortMem(incoming()) &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }

    // learning_items Collection
    match /learning_items/{itemId} {
      allow get: if isSignedIn() && 
                 isValidId(itemId) && 
                 existing().userId == request.auth.uid;
                 
      allow list: if isSignedIn() && 
                  resource.data.userId == request.auth.uid;

      allow create: if isVerified() && 
                    isValidId(itemId) && 
                    isValidLearningItem(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid));
                    
      allow update: if false;
      allow delete: if false;
    }

    // sync_ledger Collection
    match /sync_ledger/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() &&
                    isValidId(txId) &&
                    isValidLedgerEntry(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update, delete: if false;
    }

    // arena_sessions Collection
    match /arena_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
